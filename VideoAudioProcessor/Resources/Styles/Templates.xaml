<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DataTemplate x:Key="InformationResultItemTemplate">
        <Border Margin="0,0,0,10"
                Padding="10"
                Background="{DynamicResource SurfaceStrongBrush}"
                BorderBrush="{DynamicResource SurfaceBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <StackPanel>
                <DockPanel>
                    <TextBlock Text="{Binding Title}"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontWeight="SemiBold" />
                    <Border DockPanel.Dock="Right"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="10"
                            Padding="8,3"
                            Margin="8,0,0,0">
                        <TextBlock Text="{Binding Category}"
                                   Foreground="White"
                                   FontSize="11" />
                    </Border>
                </DockPanel>
                <TextBlock Text="{Binding Location}"
                           Foreground="{DynamicResource StatusBrush}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding ShortText}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap"
                           MaxHeight="54" />
            </StackPanel>
        </Border>
    </DataTemplate>
</ResourceDictionary>
