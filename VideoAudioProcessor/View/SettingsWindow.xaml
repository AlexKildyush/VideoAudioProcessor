<Window x:Class="VideoAudioProcessor.View.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки"
        Width="620"
        Height="290"
        Background="{DynamicResource WindowBackgroundBrush}"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SurfaceCardStyle}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="24" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="Тема"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <StackPanel Grid.Row="0" Grid.Column="1">
                    <CheckBox x:Name="LightThemeCheckBox"
                              Content="Светлая"
                              Margin="0,0,0,8"
                              Checked="LightThemeCheckBox_Checked"
                              Unchecked="LightThemeCheckBox_Unchecked" />
                    <CheckBox x:Name="DarkThemeCheckBox"
                              Content="Тёмная"
                              Checked="DarkThemeCheckBox_Checked"
                              Unchecked="DarkThemeCheckBox_Unchecked" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="Корневая папка"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Top"
                           Margin="0,6,0,0" />
                <Grid Grid.Row="2" Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox x:Name="RootPathTextBox"
                             Grid.Row="0"
                             MinHeight="38"
                             VerticalContentAlignment="Center"
                             TextWrapping="Wrap" />

                    <Button Grid.Column="1"
                            Grid.Row="0"
                            Content="Обзор..."
                            Width="110"
                            Margin="12,0,0,0"
                            Click="BrowseRootPathButton_Click" />
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button Content="Сохранить"
                    Width="120"
                    IsDefault="True"
                    Click="SaveButton_Click" />
            <Button Content="Отмена"
                    Width="120"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
